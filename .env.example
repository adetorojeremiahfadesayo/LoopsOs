# LoopOS local API bridge
LOOPOS_API_PORT=8787
LOOPOS_VITE_PORT=5173

# Option A: LoopOS preconfigured Cognee Cloud
# Keep these server-side only. The frontend sends a demo flag, not the key.
# LOOPOS_DEMO_COGNEE_BASE_URL=https://api.cognee.ai
# LOOPOS_DEMO_COGNEE_AUTH_MODE=api-key
# LOOPOS_DEMO_COGNEE_API_KEY=your-loopos-cloud-cognee-key

# Option B: Local Cognee REST server
COGNEE_BASE_URL=http://127.0.0.1:8000
COGNEE_AUTH_MODE=none

# One-click local Cognee launcher. No user API key is required.
# For no-key local mode, keep Ollama running and pull the default model:
# ollama pull llama3.1:8b
# LOCAL_COGNEE_LLM_API_KEY=your-llm-key-for-local-cognee
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# LLM_PROVIDER=ollama
# EMBEDDING_PROVIDER=fastembed

# Option C: Local Cognee with authentication
# COGNEE_BASE_URL=http://127.0.0.1:8000
# COGNEE_AUTH_MODE=bearer
# COGNEE_API_KEY=your-local-token

# Option D: User-provided Cognee Cloud
# COGNEE_BASE_URL=https://api.cognee.ai
# COGNEE_AUTH_MODE=api-key
# COGNEE_API_KEY=your-cognee-cloud-api-key
